{
  "_meta": {
    "brand": "鍋美美食豔室",
    "source_of_truth": "iCHEF 毛利 sheet（產品成本bom表20260608）",
    "rule_write_entry": "品項生死只能從 iCHEF 發起 → 平台會推 → 官網跟改。官網/平台皆為 iCHEF 下游投影，不得各自新增 SKU。（憲法二·異動流向）",
    "rule_price": "本檔零價格。價格只存在於各店點餐平台。（憲法三）",
    "rule_naming": "display_name 用行銷名服務行銷；id/ichef_name 為穩定索引；番茄用正字、蕃茄等異體入 alternate_names。",
    "rule_module": "short_desc 與 detail_module 為可選厚度層。menu 目錄頁僅依賴 id/display_name/category/vegetarian 即可渲染上線。厚介紹為獨立頁模組，做好一個掛一個，不影響前台優化。",
    "generated": "2026-06-27",
    "counts": {
      "對客主菜單": 47,
      "加點料": 29,
      "合計": 76
    },
    "rule_dietary": "dietary 為三獨立軸（vegetarian/contains_pork/contains_egg），不可壓成單一 flag。豬/蛋/素葷一律不程式臆測，由 iCHEF 主檔或現場拍板。",
    "rule_halal_disclaimer": "提供成分層級善意提示（如含豬/含蛋），協助客人自行判斷；不提供 halal／猶太潔食等宗教潔淨認證，因設備、湯底、料理流程為混用環境。認證級保證一律不承諾。",
    "rule_classification_tiers": {
      "硬分類": "vegetarian（葷/素）= 節操，不能錯，是承諾。第一道篩選器，最外層擋住所有原則性錯誤。",
      "友善分類": "contains_pork / contains_egg / contains_allium（五辛）/ 風味說明 = 友善加值，盡力標，不做承諾，二階段補完。null=尚未驗證，非隱瞞。",
      "篩選順序": "葷素先篩 → 素鍋若含豬肉自動判葷，輪不到細緻軸。架構天然防呆。"
    },
    "rule_allium": "contains_allium 為友善分類，只標『看似素、實含五辛會誤導嚴格素食者』的品項（如黃金系列）；其餘 null，二階段隨 BOM 反查補。",
    "rule_vegetarian_definition": {
      "基準": "鍋美美素食 = 鍋邊素 = 無肉 + 含蛋；鍋具盡力分離但不承諾。",
      "節操vs承諾": "做乾淨是節操（主動善意，盡力），不等於承諾。唯一承諾＝『無肉』。鍋具分離、純素等級、五辛潔淨皆不擔保。",
      "蛋": "蛋視為中立、屬素，先過葷素篩選。素食品項可含蛋。",
      "更嚴格教義": "蛋奶素/五辛/全素等細節不在承諾範圍。誠實標示 contains_egg / contains_allium，由消費者依自身教義自行判斷。",
      "同源": "與『非 halal 但有注意』『誠實當篩選機制』同底色：只承諾守得住的，做不到的明說。"
    }
  },
